# =============================================================================
# homeassistant — ENV TEMPLATE
# Copy to .env and fill in:   cp .env.example .env   then  ./bootstrap.sh
# NEVER commit .env (gitignored).
#
# Home Assistant itself runs as an OS (HAOS) on its own VM — this repo is mainly
# the version-controlled export of that VM's config (see README), NOT a compose
# stack. This template exists so bootstrap/install run cleanly and to configure
# the per-machine edge module + any OPTIONAL containerized bits (mqtt/zigbee)
# you choose to run on this host rather than as HA add-ons.
# =============================================================================

# --- 1. SYSTEM / PATHS -------------------------------------------------------
SERVER_IP=192.168.1.100
PUID=1000
PGID=1000
TZ=America/Chicago
HOME_NETWORK=home
# App config + data (LOCAL disk)
CONFIG_PATH=/opt/docker/data
# This repo's location — set automatically by link-env / bootstrap.
STACKS_PATH=/opt/docker/homestacks/HAstack

# --- 2. PROFILES / GITOPS ----------------------------------------------------
# Which optional services come up (none by default). For ingress add: caddy / tailscale.
COMPOSE_PROFILES=
# Nightly auto-update (hs update):  on | off
GITOPS_AUTOUPDATE=on

# --- 3. EDGE — per-machine reverse proxy + mesh (edge/ module, profile-gated) --
# Caddy automatic wildcard HTTPS via Cloudflare DNS-01 (COMPOSE_PROFILES=caddy)
DOMAIN=example.com
CLOUDFLARE_DNS_API_TOKEN=
ACME_EMAIL=
# Tailscale mesh (COMPOSE_PROFILES=tailscale) — reusable, non-expiring auth key
TS_AUTHKEY=
TS_HOSTNAME=hastack
TS_EXTRA_ARGS=--accept-routes
